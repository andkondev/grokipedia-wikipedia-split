{
  "manifest_version": 3,
  "name": "Grokipedia + Wikipedia Split View",
  "version": "1.0",
  "description": "View Grokipedia with Wikipedia side-by-side",
  "permissions": ["activeTab", "notifications", "scripting", "storage", "webNavigation", "contextMenus"],
  "host_permissions": ["https://grokipedia.com/*", "https://en.wikipedia.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://grokipedia.com/*"],
    "css": ["grokipedia.css"],
    "js": ["grokipedia-early.js"],
    "run_at": "document_start"
  }, {
    "matches": ["https://*.wikipedia.org/*"],
    "js": ["wikipedia-iframe.js"],
    "run_at": "document_end",
    "all_frames": true
  }],
  "action": {
    "default_title": "Open in Grokipedia with Wikipedia"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
